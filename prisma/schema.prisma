generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER
  PLAYER
}

enum Atributo {
  FOR
  AGI
  VIG
  INT
  PRE
}

enum TipoDano {
  FISICO
  ENERGETICO
  MENTAL
  ESPIRITUAL
}

enum CombatState {
  IDLE
  COMBAT_CREATED
  INITIATIVE_ROLLED
  ROUND_ACTIVE
  ROUND_FINISHED
  COMBAT_FINISHED
}

enum ActionType {
  TECHNIQUE
  SKILL
  DAMAGE
  CONDITION
  XP
  LEVELUP
  ATAQUE
  DEFESA
  CD_TEST
  DANO
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  campaigns          Campaign[]
  characters         Character[]
  techniqueTemplates TechniqueTemplate[]
  items              Item[]
  talentos           Talento[]
}

model Campaign {
  id             String   @id @default(uuid())
  name           String
  masterId       String
  master         User     @relation(fields: [masterId], references: [id])
  isActiveCombat Boolean  @default(false)
  inviteCode     String   @unique @default(uuid())
  createdAt      DateTime @default(now())

  characters Character[]
  combats    Combat[]
  npcs       Npc[]
  logs       CombatLog[]
  gameMap    GameMap?
  scenes     Scene[]
}

model Character {
  id                    String          @id @default(uuid())
  campaignId            String
  campaign              Campaign        @relation(fields: [campaignId], references: [id])
  userId                String
  user                  User            @relation(fields: [userId], references: [id])
  nome                  String
  origemId              String?
  origemRelacao         Origem?         @relation(fields: [origemId], references: [id])
  specializationId      String?
  specialization        Specialization? @relation(fields: [specializationId], references: [id])
  nivel                 Int             @default(1)
  xpAtual               Int             @default(0)
  hpAtual               Int             @default(10)
  hpMax                 Int             @default(10)
  energiaAtual          Int             @default(5)
  energiaMax            Int             @default(5)
  maestriaBonus         Int             @default(2)
  isApproved            Boolean         @default(false)
  isMob                 Boolean         @default(false)
  isActive              Boolean         @default(true)
  pendingAptidaoSlots   Int             @default(0)
  pendingAtributoPoints Int             @default(0)
  grau                  String          @default("4")
  avatarUrl             String?
  createdAt             DateTime        @default(now())

  attributes           CharacterAttribute?
  skills               CharacterSkill[]
  aptitudes            CharacterAptitude[]
  techniques           Technique[]
  weapons              Weapon[]
  abilities            CharacterAbility[]
  talentos             CharacterTalento[]
  combatParticipations CombatParticipant[]
  inventory            InventoryItem[]
  mapPositions         MapPosition[]
  sceneTokens          SceneToken[]
}

model Talento {
  id          String   @id @default(uuid())
  nome        String
  tipo        String   @default("ativa")
  custo       String   @default("nenhum")
  alcance     String   @default("pessoal")
  duracao     String   @default("imediato")
  descricao   String   @default("")
  damageDice  String?
  atributoBase String?
  isSystem    Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  characterTalentos CharacterTalento[]
}

model CharacterTalento {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  talentoId   String
  talento     Talento   @relation(fields: [talentoId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([characterId, talentoId])
}

model CharacterAbility {
  id           String    @id @default(uuid())
  characterId  String
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  nome         String
  tipo         String    @default("ativa")
  custo        String    @default("nenhum")
  alcance      String    @default("pessoal")
  duracao      String    @default("imediato")
  descricao    String    @default("")
  damageDice   String?
  atributoBase String?
  createdAt    DateTime  @default(now())
}

model CharacterAttribute {
  id          String    @id @default(uuid())
  characterId String    @unique
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  FOR         Int       @default(1)
  AGI         Int       @default(1)
  VIG         Int       @default(1)
  INT         Int       @default(1)
  PRE         Int       @default(1)
}

model Skill {
  id              String   @id @default(uuid())
  nome            String
  atributoBase    Atributo
  permiteMaestria Boolean  @default(true)
  descricao       String   @default("")

  characterSkills CharacterSkill[]
  weapons         Weapon[]
}

model CharacterSkill {
  id               String    @id @default(uuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  skillId          String
  skill            Skill     @relation(fields: [skillId], references: [id])
  treinada         Boolean   @default(false)
  pontosInvestidos Int       @default(0)

  @@unique([characterId, skillId])
}

model Specialization {
  id                   String   @id @default(uuid())
  nome                 String
  hpBase               Int      @default(0)
  hpPorNivel           Int
  energiaPorNivel      Int
  maestriaInicial      Int      @default(2)
  bonusAtributos       Json     @default("{\"FOR\":0,\"AGI\":0,\"VIG\":0,\"INT\":0,\"PRE\":0}")
  habilidadesTreinadas String[] @default([])

  characters Character[]
  abilities  SpecializationAbility[]
}

model Origem {
  id                   String   @id @default(uuid())
  nome                 String   @unique
  descricao            String
  bonusAtributos       Json     @default("{\"FOR\":0,\"AGI\":0,\"VIG\":0,\"INT\":0,\"PRE\":0}")
  habilidadesTreinadas String[] @default([])

  characters Character[]
}

model SpecializationAbility {
  id               String         @id @default(uuid())
  specializationId String
  specialization   Specialization @relation(fields: [specializationId], references: [id])
  nome             String         @default("")
  nivelRequerido   Int
  tipo             String         @default("ativa")
  custo            String         @default("nenhum")
  alcance          String         @default("pessoal")
  duracao          String         @default("imediato")
  descricao        String
  skillNome        String?
}

model Aptitude {
  id                    String     @id @default(uuid())
  nome                  String
  descricao             String
  prerequisitoNivel     Int        @default(1)
  prerequisitoAptidaoId String?
  prerequisitoAptidao   Aptitude?  @relation("AptitudeChain", fields: [prerequisitoAptidaoId], references: [id])
  aptitudesQuePreciso   Aptitude[] @relation("AptitudeChain")
  tipo                  String     @default("buff") // "dano", "buff", "cura"
  cooldown              Int        @default(0) // em rodadas
  criadoPorUserId       String? // opcional: quem criou essa aptidão (para rastrear)
  isSystem              Boolean    @default(false)
  createdAt             DateTime   @default(now())

  characterAptitudes CharacterAptitude[]
}

model CharacterAptitude {
  id               String    @id @default(uuid())
  characterId      String
  character        Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  aptitudeId       String
  aptitude         Aptitude  @relation(fields: [aptitudeId], references: [id], onDelete: Cascade)
  adquiridaNoNivel Int
  ativo            Boolean   @default(false)
  cooldownRestante Int       @default(0)

  @@unique([characterId, aptitudeId])
}

model Technique {
  id             String    @id @default(uuid())
  characterId    String
  character      Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  nome           String
  nivel          Int       @default(0)
  custoEnergia   Int
  atributoBase   Atributo
  skillNome      String?
  descricaoLivre String    @default("")
  tipoDano       TipoDano?
  damageDice     String?
  createdAt      DateTime  @default(now())
}

model TechniqueTemplate {
  id             String    @id @default(uuid())
  nome           String
  nivel          Int       @default(1)
  tipoDano       TipoDano?
  cd             Int?
  atributoBase   Atributo
  custoEnergia   Int       @default(0)
  descricaoLivre String    @default("")
  isSystem       Boolean   @default(false)
  createdById    String?
  createdBy      User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
}

model Weapon {
  id                 String    @id @default(uuid())
  characterId        String
  character          Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  nome               String
  skillId            String?
  skill              Skill?    @relation(fields: [skillId], references: [id])
  damageDice         String
  damageType         TipoDano
  threatRange        Int       @default(20)
  criticalMultiplier Int       @default(2)
  descricao          String    @default("")
  createdAt          DateTime  @default(now())
}

model Item {
  id          String   @id @default(uuid())
  nome        String
  descricao   String   @default("")
  tipo        String   @default("misc")
  peso        Float    @default(0)
  valor       Int      @default(0)
  isSystem    Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  inventoryItems InventoryItem[]
}

model InventoryItem {
  id          String    @id @default(uuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id])
  quantidade  Int       @default(1)
  equipado    Boolean   @default(false)
  notas       String    @default("")
  createdAt   DateTime  @default(now())

  @@unique([characterId, itemId])
}

model WeaponTemplate {
  id                 String  @id @default(uuid())
  nome               String  @unique
  categoria          String
  damageDice         String
  tipoDano           String
  distancia          String
  duasMaos           Boolean @default(false)
  requiresMarcial    Boolean @default(false)
  regraEspecial      String?
  threatRange        Int     @default(20)
  criticalMultiplier Int     @default(2)
  descricao          String  @default("")
}

model LevelProgression {
  id            String  @id @default(uuid())
  level         Int     @unique
  xpRequired    Int
  ganhoAtributo Boolean @default(false)
  ganhoMaestria Boolean @default(false)
}

model Combat {
  id               String      @id @default(uuid())
  campaignId       String
  campaign         Campaign    @relation(fields: [campaignId], references: [id])
  state            CombatState @default(IDLE)
  roundNumber      Int         @default(1)
  currentTurnIndex Int         @default(0)
  createdAt        DateTime    @default(now())
  finishedAt       DateTime?

  participants CombatParticipant[]
  logs         CombatLog[]
}

model CombatParticipant {
  id           String     @id @default(uuid())
  combatId     String
  combat       Combat     @relation(fields: [combatId], references: [id])
  characterId  String?
  character    Character? @relation(fields: [characterId], references: [id])
  npcId        String?
  npc          Npc?       @relation(fields: [npcId], references: [id])
  initiative   Int        @default(0)
  hpAtual      Int
  energiaAtual Int
  ordem        Int        @default(0)
  isDefeated   Boolean    @default(false)

  conditions ParticipantCondition[]
}

model CombatLog {
  id           String     @id @default(uuid())
  campaignId   String?
  campaign     Campaign?  @relation(fields: [campaignId], references: [id])
  combatId     String?
  combat       Combat?    @relation(fields: [combatId], references: [id])
  actor        String
  actionType   ActionType
  diceResult   Int?
  total        Int?
  target       String?
  wasOutOfTurn Boolean    @default(false)
  details      Json?
  timestamp    DateTime   @default(now())
}

model Npc {
  id           String   @id @default(uuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id])
  nome         String
  isSimplified Boolean  @default(false)

  hpAtual      Int      @default(10)
  hpMax        Int      @default(10)
  energiaAtual Int      @default(5)
  energiaMax   Int      @default(5)
  bonusAtaque  Int      @default(0)
  defesa       Int      @default(10)
  danoFixo     Int      @default(0)
  tipoDano     TipoDano @default(FISICO)

  nivel         Int @default(1)
  maestriaBonus Int @default(2)

  attributes           NpcAttribute?
  combatParticipations CombatParticipant[]
  mapPositions         MapPosition[]
  sceneTokens          SceneToken[]
}

model NpcAttribute {
  id    String @id @default(uuid())
  npcId String @unique
  npc   Npc    @relation(fields: [npcId], references: [id], onDelete: Cascade)
  FOR   Int    @default(1)
  AGI   Int    @default(1)
  VIG   Int    @default(1)
  INT   Int    @default(1)
  PRE   Int    @default(1)
}

model Condition {
  id             String @id @default(uuid())
  nome           String
  descricao      String
  duracaoRodadas Int
  efeitoMecanico Json   @default("[]")

  participantConditions ParticipantCondition[]
}

model ParticipantCondition {
  id               String            @id @default(uuid())
  participantId    String
  participant      CombatParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  conditionId      String
  condition        Condition         @relation(fields: [conditionId], references: [id])
  rodadasRestantes Int
  appliedAt        DateTime          @default(now())
}

// ─── Game Map ────────────────────────────────────────────────────────────────

model GameMap {
  id         String   @id @default(uuid())
  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  width      Int      @default(30)
  height     Int      @default(30)
  tiles      Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  positions MapPosition[]
}

model MapPosition {
  id          String    @id @default(uuid())
  gameMapId   String
  gameMap     GameMap   @relation(fields: [gameMapId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  npcId       String?
  npc         Npc?       @relation(fields: [npcId], references: [id], onDelete: Cascade)
  x           Int        @default(0)
  y           Int        @default(0)
  updatedAt   DateTime   @updatedAt

  @@unique([gameMapId, characterId])
  @@unique([gameMapId, npcId])
}

// ─── Scenes (Cenários) ──────────────────────────────────────────────────────

model Scene {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  nome       String
  imageUrl   String
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())

  tokens SceneToken[]
}

model SceneToken {
  id          String     @id @default(uuid())
  sceneId     String
  scene       Scene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)
  npcId       String?
  npc         Npc?       @relation(fields: [npcId], references: [id], onDelete: Cascade)
  xPct        Float      @default(50)
  yPct        Float      @default(50)
  updatedAt   DateTime   @updatedAt

  @@unique([sceneId, characterId])
  @@unique([sceneId, npcId])
}
